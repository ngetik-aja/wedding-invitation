# Database
DATABASE_URL=postgresql://user:password@host:5432/dbname

# JWT secrets — use long random strings (e.g. openssl rand -hex 32)
ADMIN_JWT_SECRET=change_me
CUSTOMER_JWT_SECRET=change_me

# App environment: development | production
APP_ENV=development

# CORS — comma-separated allowed origins (leave empty to allow all)
CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://admin.yourdomain.com

# Admin cookie settings
ADMIN_COOKIE_DOMAIN=yourdomain.com
ADMIN_COOKIE_SECURE=true
ADMIN_COOKIE_SAMESITE=none

# Midtrans payment gateway
MIDTRANS_CLIENT_KEY=Mid-client-xxx
MIDTRANS_SERVER_KEY=Mid-server-xxx
# MIDTRANS_BASE_URL=https://api.midtrans.com  # defaults to sandbox unless APP_ENV=production

# Mayar payment gateway
MAYAR_API_KEY=
MAYAR_WEBHOOK_TOKEN=
